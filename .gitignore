# Config lokal dengan credentials hardcoded — jangan commit jika masih pakai nilai lokal
# database.php dan config.php SUDAH AMAN di-commit karena pakai getenv()

# Upload files — jangan commit ke git (data user)
uploads/

# Session & cache runtime
application/cache/sessions/
application/cache/import_tmp/
application/logs/

# macOS
.DS_Store

# SQL setup files (berisi password default)
siberkah_sumut_v4_setup.sql
landing_migration.sql

# Seed data — JANGAN commit, berisi data sensitif dari DB lokal
database/seed_data.sql

# IDE
.vscode/
.idea/

# PHP local config override
php.ini
.user.ini
